# Home Network Server Configuration
# Copy this file to .env and update with your values

# Domain
DOMAIN=woggles.work

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Chicago

# Server IP — set to your server's LAN IP
SERVER_IP=192.168.0.243

# Admin email — used for Let's Encrypt certificate notifications
ADMIN_EMAIL=

# Pi-hole
PIHOLE_PASSWORD=changeme
# Pi-hole API Key (Settings > API in Pi-hole web UI after first run)
PIHOLE_API_KEY=
PIHOLE_DNS=8.8.8.8;1.1.1.1

# Traefik / Cloudflare DNS-01
# Create a scoped token at dash.cloudflare.com > Profile > API Tokens
# Permissions: Zone:DNS:Edit for woggles.work only
CF_DNS_API_TOKEN=

# Traefik dashboard BasicAuth
# Generate with: htpasswd -nB admin  (install apache2-utils if needed)
# Escape each $ in the hash with $$ when pasting here
# Example: admin:$$2y$$05$$abc123...
TRAEFIK_DASHBOARD_USERS=

# Jellyfin
# Get from Jellyfin: Dashboard > API Keys after first run
JELLYFIN_API_KEY=
# Render device GID for VA-API hardware transcoding
# Run on server: getent group render | cut -d: -f3
RENDER_GID=44

# Portainer
# Get from Portainer: Account Settings > Access Tokens after first run
PORTAINER_API_KEY=
# Find environment ID: curl -H "X-API-Key: <your-token>" http://localhost:9000/api/endpoints | jq '"PORTAINER_ENV_ID=\(.results[0].Id // .[0].Id)"'
PORTAINER_ENV_ID=

# FileBrowser
# Default login is admin/admin — change the password immediately after first login
# Root directory exposed in the FileBrowser web UI
FILEBROWSER_PATH=/mnt/data

# Media and sync paths (change when external HDD is mounted)
MEDIA_PATH=/mnt/media  # Jellyfin media library root (mounted read-only)
SYNC_PATH=/mnt/sync    # Syncthing data directory
